{
  "name": "telecast",
  "type": "module",
  "version": "0.4.0",
  "private": false,
  "description": "Telecast — a self-hosted, statically-generated microblog that mirrors your Telegram channel into a fast, searchable, and beautifully designed website built with Next.js, React, shadcn/ui, Radix UI, and Tailwind CSS. Features full-text Lunr search, i18n, a command palette, syntax-highlighted code blocks, video playback, and automatic media mirroring — all compiled to pure static HTML at build time.",
  "author": {
    "name": "Anda Toshiki",
    "email": "hi@toshi1ki.de",
    "url": "https://toshiki.dev"
  },
  "license": "AGPL-3.0",
  "homepage": "https://github.com/andatoshiki/telecast",
  "repository": {
    "type": "git",
    "url": "https://github.com/andatoshiki/telecast.git"
  },
  "bugs": {
    "url": "https://github.com/andatoshiki/telecast/issues"
  },
  "keywords": [
    "telecast",
    "telegram",
    "telegram-channel",
    "microblog",
    "static-site-generator",
    "nextjs",
    "react",
    "shadcn-ui",
    "radix-ui",
    "tailwindcss",
    "typescript",
    "i18n",
    "ssg",
    "self-hosted",
    "lunr-search"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm sync -og-image --favicon && pnpm dev:next",
    "dev:next": "next dev -p 4321",
    "build": "pnpm sync --og-image --favicon && next build --webpack",
    "start": "next start -p 4321",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "sync": "node --import tsx scripts/sync-static-content.ts",
    "og:image": "node --import tsx scripts/generate-og-image.ts",
    "release": "changelogen --release && git push --follow-tags",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "@number-flow/react": "^0.6.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.7",
    "cheerio": "1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dayjs": "^1.11.19",
    "dplayer": "github:tsukumijima/DPlayer#v1.32.7",
    "flourite": "^1.3.0",
    "lru-cache": "^11.2.4",
    "lucide-react": "^0.542.0",
    "lunr": "^2.3.9",
    "motion": "^12.36.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "ofetch": "^1.5.1",
    "prismjs": "^1.30.0",
    "prismjs-components-importer": "^0.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sanitize-html": "^2.17.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "twemoji": "^14.0.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/lunr": "^2.3.7",
    "@types/node": "^24.10.1",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/sanitize-html": "^2.16.1",
    "autoprefixer": "^10.4.23",
    "changelogen": "^0.6.1",
    "eslint": "^9.39.1",
    "eslint-plugin-format": "^2.0.1",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "dplayer"
    ]
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm commitlint --edit $1"
  }
}
